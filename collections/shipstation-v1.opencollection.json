            "method": "POST",
            "url": "https://ssapi.shipstation.com/orders",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new order or updates an existing order. This call does not support partial updates. The entire resource must be provided in the body of the request."
