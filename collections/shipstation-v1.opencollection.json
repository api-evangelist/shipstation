              {
                "name": "createDateEnd",
                "value": "",
                "type": "query",
                "description": "Returns orders that were created in ShipStation before the specified date"
              },
              {
                "name": "modifyDateStart",
                "value": "",
                "type": "query",
                "description": "Returns orders modified after the specified date"
